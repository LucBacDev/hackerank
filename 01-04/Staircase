<?php

/*
 * Complete the 'staircase' function below.
 *
 * The function accepts INTEGER n as parameter.
 */

function staircase($n) {
    if (!is_numeric($n) || $n < 1 || $n > 100) {
        return;
    }
    for ($i = 1; $i <= $n; $i++) {
        for ($j = 1; $j <= $n - $i; $j++) echo " ";
        for ($j = 1; $j <= $i; $j++) echo "#";
        echo "\n";
    }

}

$n = intval(trim(fgets(STDIN)));

staircase($n);
